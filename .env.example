# Copie para .env e ajuste

# Caminho ABSOLUTO para o seu vault do Obsidian (ou ./vault para testar local)
VAULT_PATH=./vault

# --- Treino ---
DOOM_SCENARIO=defend_the_center
TOTAL_TIMESTEPS=2000000
N_ENVS=8

# Mostra a janela do Doom (1=sim). Força N_ENVS=1, mais lento. Bom p/ demo.
RENDER=0
# Liga/desliga a documentação no Obsidian (0=treino puro, mais leve).
DOCS_ENABLED=1

# --- Modo CAMPANHA (mapas completos de um WAD, em ordem) ---
# 1 = joga mapas inteiros e avança para o próximo (currículo por timesteps).
CAMPAIGN=0
# WAD com os mapas. Vazio = usa o freedoom2.wad embutido (gratuito).
# Para os mapas do DOOM 1 originais, aponte para o seu doom.wad:
#   WAD_PATH=/caminho/para/doom.wad
WAD_PATH=
# Lista de mapas, em ordem. freedoom2 usa MAP01..MAP32; doom.wad usa E1M1..E1M8.
#   Doom 1 (episódio 1): MAPS=E1M1,E1M2,E1M3,E1M4,E1M5,E1M6,E1M7,E1M8
MAPS=MAP01,MAP02,MAP03,MAP04,MAP05
# Timesteps treinados em cada mapa antes de avançar.
STEPS_PER_MAP=200000
# Repetir a lista de mapas ao chegar no fim (1=sim).
LOOP_MAPS=0
# "Completar" = sobreviver até a saída/timeout OU matar este nº de inimigos.
KILLS_TO_CLEAR=5
# Duração máxima de um episódio, em ticks (~35/s). 2100 ≈ 60s.
EPISODE_TIMEOUT=2100

# --- Documentação (LLM LOCAL via Ollama) ---
# Sem API key, roda 100% local. Servidor: `ollama serve` (ou o app).
OLLAMA_HOST=http://localhost:11434
# Modelo leve padrão (~1.9GB, rápido no M5 16GB):
OLLAMA_MODEL=qwen2.5:7b
# Alternativas (mais qualidade, mais peso):
#   OLLAMA_MODEL=qwen2.5:7b               # ~4.7GB, melhor escrita
#   OLLAMA_MODEL=llama3.1:8b              # ~4.7GB, generalista
#   OLLAMA_MODEL=qwen2.5:14b-instruct     # ~9GB, mais qualidade, mais lento

# Escreve uma nota a cada N timesteps (somados entre todos os envs)...
WRITE_EVERY_STEPS=50000
# ...mas só se alguma métrica variou além deste limiar relativo (0.15 = 15%)
NOVELTY_THRESHOLD=0.15

# Durante o treino, os snapshots "novos" são gravados aqui (sem LLM, não trava).
# As notas são geradas DEPOIS do treino (writer.process_run), em lote.
PENDING_DIR=./.cache/pending_runs
# DICA: como o LLM agora roda só no fim, vale usar um modelo MAIOR só p/ as notas:
#   python -m writer.process_run --model qwen2.5:7b

# --- Loop de feedback (Obsidian -> treino) ---
# O treino relê 00-index/control.md a cada N steps e se adapta SEM reiniciar:
# edite stop_training/novelty_threshold/write_every_steps lá no Obsidian.
CONTROL_ENABLED=1
CONTROL_EVERY_STEPS=4096
