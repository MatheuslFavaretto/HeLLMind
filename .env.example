# Copy to .env and adjust

# ABSOLUTE path to your Obsidian vault (or ./vault for local testing)
VAULT_PATH=./vault

# --- Training ---
DOOM_SCENARIO=defend_the_center
TOTAL_TIMESTEPS=2000000
N_ENVS=8
# Seed (vary it for multi-seed A/B experiments).
SEED=42
# Note: resuming a saved brain keeps ITS saved hyperparameters — changing
# LEARNING_RATE/GAMMA/etc. here only takes effect on a fresh run (--fresh).
# Recurrent policy (LSTM via RecurrentPPO): temporal memory across steps. Opt-in; the
# brain format differs, so an LSTM brain won't load a feed-forward one (use --fresh to
# switch). Both train and eval must agree on this flag.
USE_LSTM=0

# Show the Doom window (1=yes). Forces N_ENVS=1, slower. Good for a demo.
RENDER=0
# Turn Obsidian documentation on/off (0=pure training, lighter).
DOCS_ENABLED=1

# --- CAMPAIGN mode (full WAD maps, in order) ---
# 1 = play full maps and advance to the next (curriculum by timesteps).
CAMPAIGN=0
# WAD with the maps. Empty = use the bundled freedoom2.wad (free).
# For the original DOOM 1 maps, point to your doom.wad:
#   WAD_PATH=/path/to/doom.wad
WAD_PATH=
# Map list, in order. freedoom2 uses MAP01..MAP32; doom.wad uses E1M1..E1M8.
#   Doom 1 (episode 1): MAPS=E1M1,E1M2,E1M3,E1M4,E1M5,E1M6,E1M7,E1M8
MAPS=MAP01,MAP02,MAP03,MAP04,MAP05
# Timesteps trained on each map before advancing.
STEPS_PER_MAP=200000
# Loop the map list when reaching the end (1=yes).
LOOP_MAPS=0
# "Complete" = survive to the exit/timeout OR kill this many enemies.
KILLS_TO_CLEAR=5
# Max episode duration, in ticks (~35/s). 2100 ~= 60s.
EPISODE_TIMEOUT=2100

# --- Documentation (LOCAL LLM via Ollama) ---
# No API key, runs 100% local. Server: `ollama serve` (or the app).
OLLAMA_HOST=http://localhost:11434
# Light default (~1.9GB, fast on M5 16GB):
OLLAMA_MODEL=qwen2.5:7b
# Alternatives (more quality, more weight):
#   OLLAMA_MODEL=qwen2.5:7b               # ~4.7GB, better writing
#   OLLAMA_MODEL=llama3.1:8b              # ~4.7GB, generalist
#   OLLAMA_MODEL=qwen2.5:14b-instruct     # ~9GB, more quality, slower

# Write a note every N timesteps (summed across all envs)...
WRITE_EVERY_STEPS=50000
# ...but only if some metric varied beyond this relative threshold (0.15 = 15%)
NOVELTY_THRESHOLD=0.15

# During training, "new" snapshots are saved here (no LLM, doesn't block).
# Notes are generated AFTER training (writer.process_run), in batch.
PENDING_DIR=./.cache/pending_runs
# TIP: since the LLM now runs only at the end, use a BIGGER model for the notes:
#   python -m writer.process_run --model qwen2.5:7b

# --- LLM cost knobs (lower = less RAM/CPU, faster) ---
# The fact sheet is tiny, so a big context is wasteful. Smaller num_ctx = less
# memory; num_predict caps generation; keep_alive keeps the model warm in the batch.
LLM_NUM_CTX=4096
LLM_NUM_PREDICT=700
LLM_KEEP_ALIVE=5m
# Max new concept notes that get an LLM-written body per checkpoint (rest are stubs).
MAX_NEW_CONCEPTS_PER_CKPT=2

# --- Feedback loop (Obsidian -> training) ---
# Training re-reads 00-index/control.md every N steps and adapts:
# edit stop_training/novelty_threshold/write_every_steps there in Obsidian.
CONTROL_ENABLED=1
CONTROL_EVERY_STEPS=4096

# --- Reward shaping weights (tunable; Phase 6 can suggest changes) ---
HIT_REWARD=1.0
MISS_PENALTY=0.25
DAMAGE_TAKEN_PENALTY=0.05
DEATH_PENALTY=5.0
# Campaign kill bonus (per enemy). The strongest combat lever — raise it on maps where the
# agent avoids fighting. (Campaign uses COMBINED actions w/ forced-forward, so it can
# actually move-and-shoot; a naive one-hot space made it back away and never engage.)
KILL_REWARD=5.0
# Campaign only: count-based bonus the first time a NEW weapon slot is wielded in an
# episode (the spawn weapon is pre-seeded, so only real switches pay out). 0 = off.
WEAPON_VARIETY_REWARD=0.5
# Closed loop (bestiary -> reward): scale the kill bonus by the per-monster threat the agent
# LEARNED (deadlier type = worth more to kill). Needs a prior run's bestiary. 1=on, 0=off.
BESTIARY_REWARD=0
# Post-training, an LLM proposes tweaks to the weights above (you approve via .env).
SUGGEST_REWARDS=1

# --- Cognitive memory (persists ACROSS runs) ---
# Records episode-end events (death/success/timeout) during training (cheap, async),
# and post-training an LLM extracts reusable "lessons" from them into 60-lessons/.
MEMORY_ENABLED=1
# Default: <VAULT_PATH>/.memory  (set MEMORY_DIR to override).
MEMORY_DIR=
# Minimum events before reflection runs (avoids lessons from too little data).
MIN_EVENTS_FOR_LESSONS=10
