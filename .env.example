# Local Obsidian vault path (or ./vault for local testing)
VAULT_PATH=./vault

# --- Training ---
TOTAL_TIMESTEPS=1000000
N_ENVS=4
RENDER=0
DOCS_ENABLED=1
# Seed (vary it for multi-seed A/B; RL is noisy, one seed can mislead).
SEED=42
# Recurrent policy (LSTM via RecurrentPPO) — temporal memory across steps. Opt-in; the
# brain format differs, so it won't load a feed-forward brain (needs --fresh to switch).
# (Validated: no clear gain over CnnPolicy at 250k on dense MAP02.)
USE_LSTM=0

# --- CAMPAIGN mode (full Doom maps, in order) ---  <<< this is the fix
CAMPAIGN=1
# Empty = bundled freedoom2.wad (free maps). Point to your doom.wad for the originals.
WAD_PATH=
# Campaign maps, in order. freedoom2 uses MAP01..MAP32.
MAPS=MAP01,MAP02,MAP03,MAP04,MAP05
# Timesteps trained on each map before moving on (5 maps x 200k = 1,000,000).
STEPS_PER_MAP=200000
LOOP_MAPS=0
KILLS_TO_CLEAR=5
EPISODE_TIMEOUT=2800    # 700 passos — tempo de navegar até a saída (era 350, curto demais)
                        # rollout (n_steps=512). episode≈rollout was killing GAE/advantages.
# PPO rollout/minibatch (tunable). Short n_steps -> good advantages + small obs buffer.
N_STEPS=1024            # >= episódio para o GAE estimar vantagens bem
BATCH_SIZE=256

# --- Reward shaping (anti-idle, then re-tuned for COMBAT) ---
# The +500k run collapsed to 0 kills: movement reward dominated and the miss-penalty
# discouraged shooting. Re-tuned so landing hits beats wandering.
HIT_REWARD=3.0          # was 1.0 — a hit must be worth more than moving
MISS_PENALTY=0.01        # was 0.05 — don't punish *trying* to shoot
MOVE_REWARD=0.0001      # tiny floor: prevents passivity without farming-by-spinning
LIVING_REWARD=-0.01    # increased: more pressure to act (anti-passivity)
DAMAGE_TAKEN_PENALTY=0.1
DEATH_PENALTY=5.0       # low so a kill is worth the risk of dying (avoids cowardice)
# Campaign kill bonus per enemy — the strongest combat lever (raise where it won't fight).
KILL_REWARD=5.0
# Count-based bonus the FIRST time a new weapon slot is wielded per episode (spawn weapon
# pre-seeded, so only real switches pay). 0 = off.
WEAPON_VARIETY_REWARD=0.5
# ANTI-CIRCLE: rewards only NET outward progress (a new max distance from spawn), which
# spinning in circles can't farm — unlike raw MOVE_REWARD, which pays per distance and so
# literally rewards driving in circles. Flip this ON (e.g. 0.01) to fight the spin + push
# exploration. Pair it with MOVE_REWARD=0 and a higher COVERAGE_REWARD.
FRONTIER_REWARD=0.05    # Teste C: raised (behavior detector: 0.02 not enough vs kill-at-spawn optimum)
# Closed loop (bestiary -> reward): scale the kill bonus by the per-monster threat the agent
# LEARNED (the monsters that actually kill it are worth more). Needs a prior run's bestiary.
BESTIARY_REWARD=1
# Post-training, an LLM proposes tweaks to the weights above (you approve via .env).
SUGGEST_REWARDS=1

# --- Exploration & completion (goal: explore the whole map and FINISH it) ---
# Bonus the first time the agent steps on a NEW grid cell (count-based exploration).
# Replaces raw move_reward as the exploration driver. 0 = off.
COVERAGE_REWARD=2.0     # Teste C: raised to compete with kill-at-spawn incentive
# Grid cell size (map units) for the coverage reward AND the spatial memory.
COVERAGE_CELL=96.0
# Big prize for actually reaching the level EXIT (ended, not dead, before timeout).
EXIT_REWARD=1000.0
# Feed the agent a 2nd observation channel of where it has already been (spatial
# memory) so it ACTS on its memory. NOTE: changes the obs shape -> needs --fresh.
SPATIAL_MEMORY=1
# Intrinsic curiosity (RND): position-based bonus that never saturates.
USE_RND=1
RND_SCALE=0.3           # levemente menor (temos dois sinais de exploração agora)

# --- Cognitive memory (persists ACROSS runs) ---
# Records episode-end events (death/success/timeout) during training (cheap, async),
# and post-training an LLM extracts reusable "lessons" from them into 60-lessons/.
MEMORY_ENABLED=1
# Default: <VAULT_PATH>/.memory  (set MEMORY_DIR to override).
MEMORY_DIR=
# Minimum events before reflection runs (avoids lessons from too little data).
MIN_EVENTS_FOR_LESSONS=10

# --- Documentation (local LLM via Ollama) ---
OLLAMA_HOST=http://localhost:11434
# Light + available model (your 7b-instruct tag isn't pulled). For nicer final notes:
#   python -m writer.process_run --model qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b

WRITE_EVERY_STEPS=50000   # was 10000 — fewer, richer notes; far less Ollama load
NOVELTY_THRESHOLD=0.15
# --- Intelligence upgrades (opt-in; each forces --fresh if it changes obs shape) ---
# Depth perception: ViZDoom depth buffer as an extra obs channel (3D structure). Needs --fresh.
DEPTH_PERCEPTION=1
# Go-Explore "return, then explore": prob an episode is handed a far frontier cell as a goal.
GOEXPLORE_GOAL_PROB=0.4
GOEXPLORE_GOAL_SCALE=0.02
GOEXPLORE_REACH_RADIUS=96.0

# --- ViZDoom perception/action upgrades (opt-in) ---
# Strafe actions (sideways movement). Changes action count -> needs --fresh.
STRAFE=1
# Native top-down automap as an obs channel (allocentric layout). Needs --fresh.
AUTOMAP=1
# Labels buffer: ground-truth on-screen enemy detection (telemetry + engagement reward).
USE_LABELS=1
# Tiny bonus for keeping a visible enemy centred (needs USE_LABELS=1). 0 = off.
ENGAGEMENT_REWARD=0.01

# Entropy bonus — 0.01 causava argmax-collapse (política congela no argmax). 0.03+ resolve.
ENT_COEF=0.03

# Temperatura com que o auto/eureka PONTUAM a política (não argmax puro, que colapsa).
# 0 = argmax | 0.5 = temperada (recomendado — mede a capacidade real do agente).
EVAL_TEMPERATURE=0.5

# frame_stack=2 para caber todos os canais de obs (spatial+depth+automap) na RAM.
FRAME_STACK=2

# Game-vars: o agente recebe HEALTH+AMMO normalizados na política (sabe a própria vida).
# Cria um brain health-aware (_gv). Muda a obs -> precisa de brain fresh.
GAME_VARS=1

# Combat/exploration decoupling (champion-style, needs USE_LABELS=1): pursue ONE objective at
# a time. 1=on. factor = how hard to damp the off-mode rewards (0.25 = keep 25%).
COMBAT_EXPLORE_SPLIT=1
COMBAT_EXPLORE_FACTOR=0.25
