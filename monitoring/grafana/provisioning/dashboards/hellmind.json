{
  "annotations": {"list": []},
  "editable": true,
  "title": "HeLLMind — agent metrics",
  "uid": "hellmind",
  "tags": ["hellmind", "doom", "rl"],
  "timezone": "",
  "schemaVersion": 39,
  "time": {"from": "now-7d", "to": "now"},
  "refresh": "30s",
  "templating": {"list": []},
  "panels": [
    {"type": "row", "title": "AIM", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}},
    {"type": "stat", "title": "Aim offset (0=centred)", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
     "fieldConfig": {"defaults": {"min": 0, "max": 1, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 0.5}]}}},
     "targets": [{"expr": "hellmind_aim_offset", "refId": "A"}]},
    {"type": "stat", "title": "Wasted shots %", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "gridPos": {"h": 6, "w": 6, "x": 6, "y": 1},
     "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 0.4}]}}},
     "targets": [{"expr": "hellmind_wasted_shot_rate", "refId": "A"}]},
    {"type": "timeseries", "title": "Shooting accuracy / kill conversion", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "gridPos": {"h": 6, "w": 12, "x": 12, "y": 1},
     "fieldConfig": {"defaults": {"unit": "percentunit"}},
     "targets": [{"expr": "hellmind_shooting_accuracy", "legendFormat": "accuracy", "refId": "A"},
                 {"expr": "hellmind_kill_conversion", "legendFormat": "kill conversion", "refId": "B"}]},

    {"type": "row", "title": "MOVEMENT & OBJECTIVE", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7}},
    {"type": "timeseries", "title": "Explored fraction", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
     "fieldConfig": {"defaults": {"unit": "percentunit"}},
     "targets": [{"expr": "hellmind_explored_fraction", "legendFormat": "explored", "refId": "A"},
                 {"expr": "hellmind_revisit_rate", "legendFormat": "revisit (circling)", "refId": "B"}]},
    {"type": "timeseries", "title": "Exit progress", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8},
     "fieldConfig": {"defaults": {"unit": "percentunit"}},
     "targets": [{"expr": "hellmind_exit_progress", "legendFormat": "exit progress", "refId": "A"}]},
    {"type": "timeseries", "title": "Kills/ep & death rate", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
     "targets": [{"expr": "hellmind_kills_per_episode", "legendFormat": "kills/ep", "refId": "A"},
                 {"expr": "hellmind_death_rate", "legendFormat": "death rate", "refId": "B"}]},

    {"type": "row", "title": "WHAT IT OPTIMISES (reward breakdown)", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}},
    {"type": "timeseries", "title": "Reward breakdown by component", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "gridPos": {"h": 7, "w": 12, "x": 0, "y": 15},
     "fieldConfig": {"defaults": {"unit": "percentunit", "custom": {"stacking": {"mode": "normal"}}}},
     "targets": [{"expr": "hellmind_reward_breakdown", "legendFormat": "{{item}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Weapon usage (share of time)", "datasource": {"type": "prometheus", "uid": "prometheus"},
     "gridPos": {"h": 7, "w": 12, "x": 12, "y": 15},
     "fieldConfig": {"defaults": {"unit": "percentunit"}},
     "targets": [{"expr": "hellmind_weapons_used", "legendFormat": "{{item}}", "refId": "A"}]}
  ]
}
